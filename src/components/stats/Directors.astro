---
import { directorCounts } from '../../data/movies.ts';

const directorsArray = Array.from(directorCounts).sort(([, c1], [, c2]) => c2 - c1);
---

    <div class="gap-2">
      <div class="columns-2 lg:columns-5">
        <table>
          <tbody>
            {
              directorsArray.map(([director, count]) => (
                <tr class="text-sm">
                  <td>{director}</td>
                  <td class="text-center">{count}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
